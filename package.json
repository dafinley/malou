{
  "name": "molou",
  "version": "0.1.0",
  "private": false,
  "description": "A visual workbench for understanding model training methods, from full training to QLoRA, distillation, and RL.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dafinley/malou.git"
  },
  "keywords": [
    "machine-learning",
    "education",
    "visualization",
    "llm",
    "lora",
    "qlora",
    "distillation",
    "rlhf",
    "training",
    "ai"
  ],
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.1.0"
  },
  "overrides": {
    "zod-validation-error": "4.0.2"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "GITHUB_PAGES=true next build && bun scripts/prepare-pages.mjs",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run lint && bun run typecheck && bun run format:check"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "zod": "latest",
    "zod-validation-error": "4.0.2"
  }
}
